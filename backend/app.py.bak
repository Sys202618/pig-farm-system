@app.route('/api/sales_records', methods=['POST'])
@login_required
def create_sales():
    data = request.json or {}
    if 'total_amount' not in data or not data['total_amount']:
        data['total_amount'] = float(data.get('quantity', 0) or 0) * float(data.get('unit_price', 0) or 0)
    conn = get_db_conn()
    c = conn.cursor()
    if data.get('herd_id'):
        c.execute('SELECT farm_id, pig_type FROM herds WHERE id=?', (data['herd_id'],))
        h = c.fetchone()
        if h:
            if not data.get('farm_id'): data['farm_id'] = h['farm_id']
            if not data.get('pig_type'): data['pig_type'] = h['pig_type']
    if not data.get('farm_id') and data.get('batch_id'):
        c.execute('SELECT farm_id FROM batches WHERE id=?', (data['batch_id'],))
        b = c.fetchone()
        if b: data['farm_id'] = b['farm_id']
    if not data.get('farm_id'):
        data['farm_id'] = 1  # fallback
    qty = int(data.get('quantity', 0) or 0)
    herd_id = data.get('herd_id')
    cols_s = ['farm_id', 'batch_id', 'herd_id', 'pig_type', 'quantity', 'total_weight', 'unit_price', 'total_amount', 'buyer', 'sale_date', 'operator', 'notes']
    vals_s = [data.get(f) for f in cols_s]
    c.execute(f"INSERT INTO sales_records ({','.join(cols_s)}) VALUES ({','.join(['?']*len(cols_s))})", vals_s)
    conn.commit()
    # Decrement batch inventory on sale (only when herd was linked)
    batch_id = data.get('batch_id')
    if batch_id and herd_id and qty > 0:
        c.execute('UPDATE batches SET current_quantity=COALESCE(current_quantity,0)-? WHERE id=?', (qty, batch_id))
        conn.commit()
    return jsonify({'code': 0, 'msg': '添加成功'})
@app.route('/api/sales_records/<int:id>', methods=['PUT'])
@login_required
def update_sales(id):
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    cols = ['farm_id', 'batch_id', 'herd_id', 'pig_type', 'quantity', 'total_weight', 'unit_price', 'total_amount', 'buyer', 'sale_date', 'operator', 'notes']
    vals = [data.get(f) for f in cols] + [id]
    c.execute(f"UPDATE sales_records SET {','.join([f'{f}=?' for f in cols])} WHERE id=?", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '更新成功'})

@app.route('/api/sales_records/<int:id>', methods=['DELETE'])
@login_required
def delete_sales(id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT herd_id, batch_id, quantity FROM sales_records WHERE id=?', (id,))
    row = c.fetchone()
    qty = int(row['quantity'] or 0) if row else 0
    c.execute('DELETE FROM sales_records WHERE id=?', (id,))
    conn.commit()
    if row and row['herd_id'] and qty > 0:
        c.execute('UPDATE herds SET quantity=COALESCE(quantity,0)+?, status=? WHERE id=?', (qty, '存栏', row['herd_id']))
        conn.commit()
        if row['batch_id']:
            c.execute('UPDATE batches SET current_quantity=COALESCE(current_quantity,0)+? WHERE id=?', (qty, row['batch_id']))
            conn.commit()
    return jsonify({'code': 0, 'msg': '删除成功'})

