@app.route('/api/pig_farms', methods=['GET'])
@login_required
def list_farms():
    return crud_list('pig_farms')

@app.route('/api/pig_farms', methods=['POST'])
@login_required
def create_farm():
    return crud_create('pig_farms', ['code', 'name', 'address', 'manager', 'phone', 'stock_scale', 'built_date', 'area', 'status', 'notes'])

@app.route('/api/pig_farms/<int:id>', methods=['GET'])
@login_required
def get_farm(id):
    return crud_get('pig_farms', id)

@app.route('/api/pig_farms/<int:id>', methods=['PUT'])
@login_required
def update_farm(id):
    return crud_update('pig_farms', ['code', 'name', 'address', 'manager', 'phone', 'stock_scale', 'built_date', 'area', 'status', 'notes'], id)

@app.route('/api/pig_farms/<int:id>', methods=['DELETE'])
@login_required
def delete_farm(id):
    return crud_delete('pig_farms', id)

