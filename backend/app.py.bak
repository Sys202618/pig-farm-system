@app.route('/api/breeding_records/<int:id>', methods=['DELETE'])
@login_required
def delete_breeding(id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT batch_id FROM breeding_records WHERE id=?', (id,))
    row = c.fetchone()
    c.execute('DELETE FROM breeding_records WHERE id=?', (id,))
    conn.commit()
    if row and row['batch_id']:
        c.execute('SELECT COUNT(*) FROM breeding_records WHERE batch_id=?', (row['batch_id'],))
        remaining = c.fetchone()[0] or 0
        if remaining == 0:
            c.execute('UPDATE batches SET status=? WHERE id=?', ('进行中', row['batch_id']))
            conn.commit()
    return jsonify({'code': 0, 'msg': '删除成功'})

