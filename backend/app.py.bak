# ============ 免疫提醒 ============
@app.route('/api/immune/reminders', methods=['GET'])
@login_required
def get_immune_reminders():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id')
    sql = '''SELECT h.id as herd_id, h.herd_code, h.herd_name, h.pig_type, h.age_days, h.in_date, bt.batch_code, ip.vaccine_name, ip.immune_type, ip.immune_age, ip.immune_method, ip.dosage, ip.interval_days, ip.notes
        FROM herds h LEFT JOIN batches bt ON h.batch_id=bt.id CROSS JOIN immune_plans ip
        WHERE h.status="存栏" '''
    params = []
    if farm_id: sql += ' AND h.farm_id=?'; params.append(farm_id)
    sql += ' AND (ip.farm_id IS NULL OR ip.farm_id=h.farm_id) AND ip.status="启用" ORDER BY h.herd_code, ip.vaccine_name'
    c.execute(sql, params)
    reminders = []
    seen = set()
    for herd in c.fetchall():
        h = row2dict(herd)
        key = (h.get('herd_id'), h.get('vaccine_name'))
        if key not in seen:
            seen.add(key)
            reminders.append(h)
    return jsonify({'code': 0, 'data': reminders})

