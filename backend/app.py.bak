@app.route('/api/immune_records', methods=['GET'])
@login_required
def list_immune_records():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id')
    batch_id = request.args.get('batch_id')
    keyword = request.args.get('keyword', '')
    sql = 'SELECT ir.*, bt.batch_code, bt.batch_name, h.herd_code, h.herd_name, h.pig_type, b.name as barn_name FROM immune_records ir LEFT JOIN batches bt ON ir.batch_id=bt.id LEFT JOIN herds h ON ir.herd_id=h.id LEFT JOIN barns b ON ir.barn_id=b.id WHERE 1=1'
    params = []
    if farm_id: sql += ' AND ir.farm_id=?'; params.append(farm_id)
    if batch_id: sql += ' AND ir.batch_id=?'; params.append(batch_id)
    if keyword: sql += ' AND (ir.vaccine_name LIKE ? OR ir.operator LIKE ?)'; params.extend([f'%{keyword}%', f'%{keyword}%'])
    sql += ' ORDER BY ir.id DESC'
    c.execute(sql, params)
    return jsonify({'code': 0, 'data': [row2dict(r) for r in c.fetchall()]})

@app.route('/api/immune_records', methods=['POST'])
@login_required
def create_immune_record():
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    if data.get('herd_id'):
        c.execute('SELECT h.farm_id, h.batch_id, h.herd_code, h.herd_name, h.pig_type, h.barn_id, b.name as barn_name FROM herds h LEFT JOIN barns b ON h.barn_id=b.id WHERE h.id=?', (data['herd_id'],))
        herd = c.fetchone()
        if herd:
            if not data.get('farm_id'): data['farm_id'] = herd['farm_id']
            if not data.get('batch_id'): data['batch_id'] = herd['batch_id']
            if not data.get('herd_code'): data['herd_code'] = herd['herd_code']
            if not data.get('herd_name'): data['herd_name'] = herd['herd_name']
            if not data.get('pig_type'): data['pig_type'] = herd['pig_type']
            if not data.get('barn_id'): data['barn_id'] = herd['barn_id']
            if not data.get('barn_name'): data['barn_name'] = herd['barn_name']
    if not data.get('farm_id') and data.get('batch_id'):
        c.execute('SELECT farm_id FROM batches WHERE id=?', (data['batch_id'],))
        b = c.fetchone()
        if b: data['farm_id'] = b['farm_id']
    if not data.get('farm_id'):
        data['farm_id'] = 1  # fallback
    cols = ['farm_id', 'herd_id', 'batch_id', 'herd_code', 'herd_name', 'pig_type', 'barn_id', 'barn_name', 'immune_date', 'vaccine_name', 'immune_type', 'immune_method', 'quantity', 'dosage', 'immune_age', 'adverse_reaction', 'operator', 'notes']
    vals = [data.get(f) for f in cols]
    c.execute(f"INSERT INTO immune_records ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
    new_id = c.lastrowid
    conn.commit()
    if data.get('herd_id'):
        c.execute('UPDATE herds SET status=? WHERE id=?', ('免疫中', data['herd_id']))
        conn.commit()
    return jsonify({'code': 0, 'msg': '创建成功', 'id': new_id})

