    params = []
    if month: sql += ' AND month=?'; params.append(month)
    c.execute(sql, params)
    total_cost = c.fetchone()['total_cost'] or 0
    sql2 = 'SELECT SUM(quantity) as head_count FROM herds WHERE status="存栏"'
    c.execute(sql2)
    head_count = c.fetchone()['head_count'] or 0
    per_head = round(total_cost / head_count, 2) if head_count > 0 else 0
    return jsonify({'code': 0, 'data': {'total_cost': total_cost, 'head_count': head_count, 'per_head': per_head}})

# ============ 导出 ============
def make_header_style():
    from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
    s = PatternFill()
    s.start_color = 'FF4472C4'
    s.fill_type = 'solid'
    f = Font(bold=True, color='FFFFFFFF')
    a = Alignment(horizontal='center', vertical='center')
    thin = Side(style='thin', color='FF000000')
    b = Border(left=thin, right=thin, top=thin, bottom=thin)
    return {'fill': s, 'font': f, 'alignment': a, 'border': b}

def apply_style(cell, style):
    for k, v in style.items():
        setattr(cell, k, v)

@app.route('/api/export/list/<page>', methods=['GET'])
@login_required
def export_list(page):
    farm_id = request.args.get('farm_id', '')
    conn = get_db_conn()
    c = conn.cursor()
    configs = {
        'farm':      {'table': 'pig_farms', 'cols': ['code', 'name', 'address', 'manager', 'phone', 'stock_scale', 'built_date', 'area', 'status', 'notes'], 'headers': ['编码', '名称', '地址', '负责人', '电话', '存栏规模', '建成时间', '面积(亩)', '状态', '备注'], 'no_farm_filter': True},
        'barn':      {'table': 'barns', 'cols': ['f.name AS farm_name', 'barn_code', 'barns.name AS name', 'barn_type', 'barns.area AS area', 'capacity', 'current_count', 'barns.status AS status', 'barns.notes AS notes'], 'headers': ['所属猪场', '猪舍编号', '名称', '类型', '面积(m2)', '容量', '当前存栏', '状态', '备注'], 'extra_sql': 'LEFT JOIN pig_farms f ON barns.farm_id=f.id', 'col_aliases': ['farm_name', 'barn_code', 'name', 'barn_type', 'area', 'capacity', 'current_count', 'status', 'notes']},
        'batch':     {'table': 'batches', 'cols': ['batch_code', 'batch_name', 'f.name AS farm_name', 'batch_type', 'start_date', 'expected_end_date', 'quantity', 'batches.status AS status', 'batches.manager AS manager', 'batches.notes AS notes'], 'headers': ['批次编号', '批次名称', '猪场', '批次类型', '开始日期', '预计结束', '头数', '状态', '负责人', '备注'], 'extra_sql': 'LEFT JOIN pig_farms f ON batches.farm_id=f.id', 'col_aliases': ['batch_code', 'batch_name', 'farm_name', 'batch_type', 'start_date', 'expected_end_date', 'quantity', 'status', 'manager', 'notes']},
        'herd':      {'table': 'herds', 'cols': ['bt.batch_code', 'bt.batch_name', 'f.name AS farm_name', 'b.name AS barn_name', 'herds.herd_code AS herd_code', 'herds.quantity AS quantity', 'herds.age_days AS age_days', 'herds.weight AS weight', 'herds.in_date AS in_date', 'herds.status AS status', 'herds.notes AS notes'], 'headers': ['批次编号', '批次名称', '猪场', '猪舍', '猪群编号', '数量', '日龄', '重量(kg)', '入群日期', '状态', '备注'], 'extra_sql': 'LEFT JOIN batches bt ON herds.batch_id=bt.id LEFT JOIN pig_farms f ON herds.farm_id=f.id LEFT JOIN barns b ON herds.barn_id=b.id', 'col_aliases': ['batch_code', 'batch_name', 'farm_name', 'barn_name', 'herd_code', 'quantity', 'age_days', 'weight', 'in_date', 'status', 'notes']},
        'employee':  {'table': 'employees', 'cols': ['f.name AS farm_name', 'employees.name AS name', 'role', 'dept', 'employees.phone AS phone', 'employees.status AS status'], 'headers': ['所属猪场', '姓名', '职位', '部门', '电话', '状态'], 'extra_sql': 'LEFT JOIN pig_farms f ON employees.farm_id=f.id', 'col_aliases': ['farm_name', 'name', 'role', 'dept', 'phone', 'status']},
        'breeding':  {'table': 'breeding_records', 'cols': ['sow_code', 'boar_code', 'breed_date', 'breed_method', 'expected_date', 'operator', 'status', 'notes'], 'headers': ['母猪号', '公猪号', '配种日期', '方式', '预产日期', '操作人', '状态', '备注']},
        'farrowing': {'table': 'farrowing_records', 'cols': ['sow_code', 'farrow_date', 'total_born', 'alive_born', 'healthy_count', 'dead_born', 'weak', 'mummy', 'avg_weight', 'litter_weight', 'notes'], 'headers': ['母猪号', '产仔日期', '总仔', '活仔', '健仔', '死胎', '弱仔', '木乃伊', '均重(kg)', '窝重(kg)', '备注']},
        'weaning':   {'table': 'weaning_records', 'cols': ['sow_code', 'wean_date', 'weaned_count', 'avg_weight', 'notes'], 'headers': ['母猪号', '断奶日期', '断奶头数', '均重(kg)', '备注']},
        'transfer':  {'table': 'transfer_records', 'cols': ['pig_type', 'from_barn', 'to_barn', 'quantity', 'transfer_date', 'operator', 'notes'], 'headers': ['猪只类型', '转出猪舍', '转入猪舍', '数量', '日期', '操作人', '备注']},
        'death':     {'table': 'death_records', 'cols': ['pig_type', 'barn_name', 'quantity', 'death_type', 'reason', 'death_date', 'operator', 'notes'], 'headers': ['猪只类型', '猪舍', '数量', '类型', '原因', '日期', '操作人', '备注']},
        'sales':     {'table': 'sales_records', 'cols': ['sale_date', 'pig_type', 'quantity', 'total_weight', 'unit_price', 'total_amount', 'buyer', 'operator', 'notes'], 'headers': ['日期', '类型', '数量', '总重量(kg)', '单价(kg)', '总金额', '买家', '操作人', '备注']},
        'income':    {'table': 'income_records', 'cols': ['income_type', 'amount', 'month', 'record_date', 'description', 'operator', 'notes'], 'headers': ['类型', '金额(元)', '月份', '日期', '描述', '操作人', '备注']},
        'cost':      {'table': 'cost_records', 'cols': ['cost_category', 'amount', 'month', 'record_date', 'description', 'operator', 'notes'], 'headers': ['类型', '金额(元)', '月份', '日期', '描述', '操作人', '备注']},
        'immune-plan':  {'table': 'immune_plans', 'cols': ['vaccine_name', 'immune_type', 'immune_age', 'immune_method', 'dosage', 'interval_days', 'status', 'notes'], 'headers': ['疫苗名称', '免疫类型', '应免日龄', '免疫方式', '剂量', '间隔天数', '状态', '备注']},
        'immune-record': {'table': 'immune_records', 'cols': ['immune_date', 'herd_name', 'pig_type', 'vaccine_name', 'immune_type', 'quantity', 'immune_method', 'dosage', 'operator', 'notes'], 'headers': ['免疫日期', '猪群', '类型', '疫苗', '免疫类型', '数量', '方式', '剂量', '操作人', '备注']},
    }
    if page not in configs:
        return jsonify({'code': 400, 'msg': '不支持的页面'})
    cfg = configs[page]
    col_aliases = cfg.get('col_aliases', cfg['cols'])
    sql = f"SELECT {','.join(cfg['cols'])} FROM {cfg['table']} {cfg.get('extra_sql', '')} WHERE 1=1"
    params = []
    if farm_id and not cfg.get('no_farm_filter'):
        sql = sql.replace('WHERE 1=1', f'WHERE {cfg["table"]}.farm_id=?')
        params.append(farm_id)
    sql += f' ORDER BY {cfg["table"]}.id DESC LIMIT 10000'
    c.execute(sql, params)
    rows = [row2dict(r) for r in c.fetchall()]
    wb = Workbook()
    ws = wb.active
    ws.title = cfg['headers'][0]
    ws.append(cfg['headers'])
    hs = make_header_style()
    for cell in ws[1]:
        apply_style(cell, hs)
    for row_data in rows:
        ws.append([row_data.get(col) for col in col_aliases])
    for col in ws.columns:
        ws.column_dimensions[col[0].column_letter].width = 18
    buf = io.BytesIO()
    wb.save(buf)
    buf.seek(0)
    from flask import make_response
    response = make_response(buf.getvalue())
    response.headers['Content-Type'] = 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
    response.headers['Content-Disposition'] = f'attachment; filename={page}_{datetime.datetime.now().strftime("%Y%m%d")}.xlsx'
    return response

# ============ 导入 ============
def parse_xlsx_sheet(file_storage):
    from openpyxl import load_workbook
    wb = load_workbook(file_storage)
    ws = wb.active
    headers = [str(c.value).strip() if c.value else '' for c in ws[1]]
    data = []
    for row in ws.iter_rows(min_row=2):
        if any(c.value for c in row):
            data.append({headers[i]: str(row[i].value).strip() if row[i].value is not None else '' for i in range(len(headers))})
    return headers, data

@app.route('/api/import/<page>', methods=['POST'])
@login_required
def batch_import(page):
    if 'file' not in request.files:
        return jsonify({'code': 400, 'msg': '请上传文件'})
    file = request.files['file']
    if not file.filename.endswith('.xlsx'):
        return jsonify({'code': 400, 'msg': '只支持xlsx格式'})
    try:
        headers, rows = parse_xlsx_sheet(file)
    except Exception as e:
        return jsonify({'code': 400, 'msg': f'解析失败: {str(e)}'})
    # page -> table name mapping (page names don't always match table names)
    page_tables = {
        'farm': 'pig_farms', 'barn': 'barns', 'batch': 'batches', 'herd': 'herds',
        'employee': 'employees', 'breeding': 'breeding_records', 'farrowing': 'farrowing_records',
        'weaning': 'weaning_records', 'transfer': 'transfer_records', 'death': 'death_records',
        'sales': 'sales_records', 'income': 'income_records', 'cost': 'cost_records',
        'immune-plan': 'immune_plans', 'immune-record': 'immune_records',
    }
    table_name = page_tables.get(page, page)

    field_maps = {
        'farm': [('编码', 'code'), ('名称', 'name'), ('地址', 'address'), ('负责人', 'manager'), ('电话', 'phone'), ('存栏规模', 'stock_scale'), ('建成时间', 'built_date'), ('面积(亩)', 'area'), ('状态', 'status'), ('备注', 'notes')],
        'barn': [('所属猪场', 'farm_id', 'farm_name_lookup'), ('猪场', 'farm_id', 'farm_name_lookup'), ('猪舍编号', 'barn_code'), ('名称', 'name'), ('类型', 'barn_type'), ('面积(m2)', 'area'), ('容量', 'capacity'), ('状态', 'status'), ('备注', 'notes')],
        'employee': [('所属猪场', 'farm_id', 'farm_name_lookup'), ('猪场', 'farm_id', 'farm_name_lookup'), ('姓名', 'name'), ('职位', 'role'), ('部门', 'dept'), ('电话', 'phone'), ('状态', 'status')],
        'breeding': [('母猪号', 'sow_code'), ('公猪号', 'boar_code'), ('配种日期', 'breed_date'), ('方式', 'breed_method'), ('预产日期', 'expected_date'), ('操作人', 'operator'), ('状态', 'status'), ('备注', 'notes')],
        'farrowing': [('母猪号', 'sow_code'), ('产仔日期', 'farrow_date'), ('总仔', 'total_born'), ('活仔', 'alive_born'), ('健仔', 'healthy_count'), ('死胎', 'dead_born'), ('弱仔', 'weak'), ('木乃伊', 'mummy'), ('均重(kg)', 'avg_weight'), ('窝重(kg)', 'litter_weight'), ('备注', 'notes')],
        'weaning': [('母猪号', 'sow_code'), ('断奶日期', 'wean_date'), ('断奶头数', 'weaned_count'), ('均重(kg)', 'avg_weight'), ('备注', 'notes')],
        'immune-plan': [('疫苗名称', 'vaccine_name'), ('免疫类型', 'immune_type'), ('应免日龄', 'immune_age'), ('免疫方式', 'immune_method'), ('剂量', 'dosage'), ('间隔天数', 'interval_days'), ('状态', 'status'), ('备注', 'notes')],
        'batch': [('批次编号', 'batch_code'), ('批次名称', 'batch_name'), ('猪场', 'farm_id', 'farm_name_lookup'), ('批次类型', 'batch_type'), ('开始日期', 'start_date'), ('预计结束日期', 'expected_end_date'), ('头数', 'quantity'), ('状态', 'status'), ('负责人', 'manager'), ('备注', 'notes')],
        'herd': [('批次编号', 'batch_id', 'batch_code_lookup'), ('猪群编号', 'herd_code'), ('猪群名称', 'herd_name'), ('猪舍', 'barn_id', 'barn_name_lookup'), ('猪只类型', 'pig_type'), ('数量', 'quantity'), ('日龄', 'age_days'), ('重量(kg)', 'weight'), ('入群日期', 'in_date'), ('状态', 'status'), ('备注', 'notes')],
        'transfer': [('猪只类型', 'pig_type'), ('转出猪舍', 'from_barn'), ('转入猪舍', 'to_barn'), ('数量', 'quantity'), ('日期', 'transfer_date'), ('操作人', 'operator'), ('备注', 'notes')],
        'death': [('猪只类型', 'pig_type'), ('猪舍', 'barn_name'), ('数量', 'quantity'), ('类型', 'death_type'), ('原因', 'reason'), ('日期', 'death_date'), ('操作人', 'operator'), ('备注', 'notes')],
        'sales': [('日期', 'sale_date'), ('类型', 'pig_type'), ('数量', 'quantity'), ('总重量(kg)', 'total_weight'), ('单价(元/kg)', 'unit_price'), ('总金额', 'total_amount'), ('买家', 'buyer'), ('操作人', 'operator'), ('备注', 'notes')],
        'income': [('类型', 'income_type'), ('金额(元)', 'amount'), ('月份', 'month'), ('日期', 'record_date'), ('描述', 'description'), ('操作人', 'operator'), ('备注', 'notes')],
        'cost': [('类型', 'cost_category'), ('金额(元)', 'amount'), ('月份', 'month'), ('日期', 'record_date'), ('描述', 'description'), ('操作人', 'operator'), ('备注', 'notes')],
        'immune-record': [('免疫日期', 'immune_date'), ('猪群编号', 'herd_id', 'herd_code_lookup'), ('猪群名称', 'herd_name'), ('猪只类型', 'pig_type'), ('疫苗名称', 'vaccine_name'), ('免疫类型', 'immune_type'), ('数量', 'quantity'), ('方式', 'immune_method'), ('剂量', 'dosage'), ('操作人', 'operator'), ('备注', 'notes')],
    }
    if page not in field_maps:
        return jsonify({'code': 400, 'msg': f'页面{page}不支持导入'})
    mapping = field_maps[page]
    conn = get_db_conn()
    c = conn.cursor()
    # Get farm_id from form data
    farm_id = request.form.get('farm_id', '')
    # Lookup helpers
    def batch_code_lookup(val):
        if not val: return None
        c.execute('SELECT id FROM batches WHERE batch_code=? LIMIT 1', (str(val),))
        r = c.fetchone()
        return r['id'] if r else None

    def barn_name_lookup(val):
        if not val: return None
        c.execute('SELECT id FROM barns WHERE name=? LIMIT 1', (str(val),))
        r = c.fetchone()
        return r['id'] if r else None

    def herd_code_lookup(val):
        if not val: return None
        c.execute('SELECT id FROM herds WHERE herd_code=? LIMIT 1', (str(val),))
        r = c.fetchone()
        return r['id'] if r else None

    imported, errors = 0, []
    for i, row in enumerate(rows):
        try:
            data = {}
            # Auto-fill farm_id from request for production records
            if farm_id and page not in ('farm', 'barn', 'employee', 'batch', 'herd'):
                data['farm_id'] = farm_id
            for old_key, new_key, *extra in mapping:
                val = row.get(old_key, '')
                if new_key == 'farm_name_lookup':
                    c.execute('SELECT id FROM pig_farms WHERE name=? LIMIT 1', (val,))
                    r = c.fetchone()
                    data['farm_id'] = r['id'] if r else None
                elif new_key == 'batch_code_lookup':
                    c.execute('SELECT id, farm_id FROM batches WHERE batch_code=? LIMIT 1', (val,))
                    r = c.fetchone()
                    if r:
                        data['batch_id'] = r['id']
                        if 'farm_id' not in data:
                            data['farm_id'] = r['farm_id']
                elif new_key == 'barn_name_lookup':
                    c.execute('SELECT id FROM barns WHERE name=? LIMIT 1', (val,))
                    r = c.fetchone()
                    data['barn_id'] = r['id'] if r else None
                elif new_key == 'herd_code_lookup':
                    c.execute('SELECT id FROM herds WHERE herd_code=? LIMIT 1', (val,))
                    r = c.fetchone()
                    data['herd_id'] = r['id'] if r else None
                elif val:
                    data[new_key] = val
            if data:
                cols = list(data.keys())
                vals = list(data.values())
                c.execute(f"INSERT INTO {table_name} ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
                imported += 1
        except Exception as e:
            errors.append(f'第{i+2}行: {str(e)}')
    conn.commit()
    result = {'code': 0, 'msg': f'成功导入{imported}条', 'imported': imported}
    if errors:
        result['errors'] = errors[:10]
    return jsonify(result)

@app.route('/api/template/<page>', methods=['GET'])
def download_template(page):
    templates = {
        'farm':         {'headers': ['编码', '名称', '地址', '负责人', '电话', '存栏规模', '建成时间', '面积(亩)', '状态', '备注'], 'rows': [['FC001', '示范猪场', '北京市顺义区', '张三', '13800138001', '5000', '2020-01-01', '50', '正常', '']]},
        'barn':         {'headers': ['所属猪场', '猪舍编号', '名称', '类型', '面积(m2)', '容量', '状态', '备注'], 'rows': [['示范猪场', 'B001', '分娩舍A', '分娩舍', '500', '60', '正常', '']]},
        'employee':     {'headers': ['所属猪场', '姓名', '职位', '部门', '电话', '状态'], 'rows': [['示范猪场', '李四', '饲养员', '生产部', '13900001111', '在职']]},
        'breeding':     {'headers': ['母猪号', '公猪号', '配种日期', '方式', '预产日期', '操作人', '状态', '备注'], 'rows': [['S001', 'B001', '2026-01-15', '人工授精', '2026-05-09', '张三', '已配种', '']]},
        'farrowing':    {'headers': ['母猪号', '产仔日期', '总仔', '活仔', '死胎', '弱仔', '均重(kg)', '备注'], 'rows': [['S001', '2026-01-20', '12', '11', '1', '0', '1.2', '']]},
        'weaning':      {'headers': ['母猪号', '断奶日期', '断奶头数', '均重(kg)', '备注'], 'rows': [['S001', '2026-02-10', '10', '6.5', '']]},
        'immune-plan':  {'headers': ['疫苗名称', '免疫类型', '应免日龄', '免疫方式', '剂量', '间隔天数', '状态', '备注'], 'rows': [['猪瘟疫苗', '基础免疫', '0', '肌注', '1头份/头', '21', '启用', '首免']]},
        'batch':        {'headers': ['批次编号', '批次名称', '猪场', '批次类型', '开始日期', '预计结束日期', '头数', '状态', '负责人', '备注'], 'rows': [['PC20260416001', '2026年第一批', '示范猪场', '育肥猪', '2026-01-01', '2026-06-30', '500', '进行中', '张三', '']]},
        'herd':         {'headers': ['批次编号', '猪群编号', '猪群名称', '猪舍', '猪只类型', '数量', '日龄', '重量(kg)', '入群日期', '状态', '备注'], 'rows': [['PC20260416001', 'H20260416001', '1号群', '育肥舍A', '育肥猪', '100', '60', '50', '2026-02-15', '存栏', '']]},
        'transfer':     {'headers': ['猪只类型', '转出猪舍', '转入猪舍', '数量', '日期', '操作人', '备注'], 'rows': [['育肥猪', '保育舍A', '育肥舍A', '50', '2026-03-01', '李四', '']]},
        'death':        {'headers': ['猪只类型', '猪舍', '数量', '类型', '原因', '日期', '操作人', '备注'], 'rows': [['育肥猪', '育肥舍A', '2', '死亡', '疾病', '2026-03-15', '王五', '']]},
        'sales':        {'headers': ['日期', '类型', '数量', '总重量(kg)', '单价(元/kg)', '总金额', '买家', '操作人', '备注'], 'rows': [['2026-04-01', '育肥猪', '50', '5000', '15', '75000', '张三', '李四', '']]},
        'income':       {'headers': ['类型', '金额(元)', '月份', '日期', '描述', '操作人', '备注'], 'rows': [['生猪销售收入', '100000', '2026-03', '2026-03-31', '3月份销售收入', '会计', '']]},
        'cost':         {'headers': ['类型', '金额(元)', '月份', '日期', '描述', '操作人', '备注'], 'rows': [['饲料成本', '50000', '2026-03', '2026-03-31', '3月份饲料', '会计', '']]},
        'immune-record': {'headers': ['免疫日期', '猪群编号', '猪群名称', '猪只类型', '疫苗名称', '免疫类型', '数量', '方式', '剂量', '操作人', '备注'], 'rows': [['2026-03-20', 'H20260416001', '1号群', '育肥猪', '猪瘟疫苗', '基础免疫', '100', '肌注', '1头份/头', '兽医', '']]},
    }
    if page not in templates:
        return jsonify({'code': 400, 'msg': '不支持'})
    cfg = templates[page]
    wb = Workbook()
    ws = wb.active
    ws.title = cfg['headers'][0]
    ws.append(cfg['headers'])
    for row_data in cfg['rows']:
        ws.append(row_data)
    for col in ws.columns:
        ws.column_dimensions[col[0].column_letter].width = 18
    buf = io.BytesIO()
    wb.save(buf)
    buf.seek(0)
    from flask import make_response
    response = make_response(buf.getvalue())
    response.headers['Content-Type'] = 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
    response.headers['Content-Disposition'] = f'attachment; filename={page}_template.xlsx'
    return response

# ============ 配置 ============
@app.route('/api/config', methods=['GET'])
def get_config():
    conn = get_db_conn()
    c = conn.cursor()
    params = {}
    c.execute('SELECT param_key, param_value FROM system_params')
    for row in c.fetchall():
        val = row['param_value']
        params[row['param_key']] = val.split(',') if val and ',' in val else val
    return jsonify({'code': 0, 'data': {
        'pig_types': ['种猪', '仔猪', '育肥猪', '后备猪', '淘汰猪'],
        'barn_types': ['分娩舍', '保育舍', '育肥舍', '配种舍', '妊娠舍', '后备舍', '隔离舍'],
        'breed_methods': ['本交', '人工授精'],
        'death_types': ['死亡', '淘汰', '扑杀'],
        'income_types': ['生猪销售收入', '仔猪销售收入', '其他收入'],
        'cost_categories': ['饲料成本', '人工成本', '水电成本', '兽药成本', '折旧摊销', '其他成本'],
        'employee_roles': ['场长', '技术员', '饲养员', '兽医', '会计', '管理员'],
        **params,
        'page_titles': {
            'farm': '猪场管理', 'barn': '猪舍管理', 'batch': '批次管理', 'herd': '猪群管理',
            'employee': '员工管理', 'breeding': '配种记录', 'farrowing': '产仔记录', 'weaning': '断奶记录',
            'transfer': '转舍记录', 'death': '死亡记录', 'sales': '销售记录',
            'income': '收入记录', 'cost': '成本记录',
            'immune-plan': '免疫计划', 'immune-record': '免疫记录',
            'home': '首页', 'params': '参数设置'
        },
    }})

@app.route('/')
def index():
    return app.send_static_file('index.html')

if __name__ == '__main__':
    data_dir = os.path.join(BASE_DIR, 'data')
    os.makedirs(data_dir, exist_ok=True)
    # Copy DB from bundled location if it doesn't exist in BASE_DIR
    db_default = os.path.join(BASE_DIR, 'data', 'pig_farm.db')
    if not os.path.exists(db_default):
        import shutil
        bundled_db = os.path.join(os.path.dirname(sys.executable) if getattr(sys, 'frozen', False) else os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'data', 'pig_farm.db')
        if os.path.exists(bundled_db):
            os.makedirs(os.path.dirname(db_default), exist_ok=True)
            shutil.copy2(bundled_db, db_default)
    print(f'Database: {DB_PATH}')
    print(f'BASE_DIR: {BASE_DIR}')
    app.run(host='0.0.0.0', port=5000, debug=True)
