@login_required
def list_barns():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id', '')
    sql = 'SELECT b.*, f.name as farm_name FROM barns b LEFT JOIN pig_farms f ON b.farm_id=f.id'
    params = []
    if farm_id:
        sql += ' WHERE b.farm_id=?'
        params.append(farm_id)
    sql += ' ORDER BY b.id DESC'
    c.execute(sql, params)
    return jsonify({'code': 0, 'data': [row2dict(r) for r in c.fetchall()]})

