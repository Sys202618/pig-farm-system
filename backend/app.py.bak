def report_monthly_income_expense():
    conn = get_db_conn()
    c = conn.cursor()
    sql = '''SELECT month,
        SUM(CASE WHEN income_type IS NOT NULL THEN amount ELSE 0 END) as income,
        SUM(CASE WHEN cost_category IS NOT NULL THEN amount ELSE 0 END) as expense
        FROM (SELECT month, amount, income_type, NULL as cost_category FROM income_records
              UNION ALL SELECT month, amount, NULL, cost_category FROM cost_records)
        GROUP BY month ORDER BY month DESC LIMIT 12'''
    c.execute(sql)
    return jsonify({'code': 0, 'data': [row2dict(r) for r in c.fetchall()]})

