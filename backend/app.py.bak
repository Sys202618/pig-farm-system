    if data.get('herd_id'):
        c.execute('UPDATE herds SET barn_id=?, status=? WHERE id=?', (data.get('to_barn'), '存栏', data['herd_id']))
        conn.commit()
    return jsonify({'code': 0, 'msg': '创建成功', 'id': new_id})

