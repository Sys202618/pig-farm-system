# -*- coding: utf-8 -*-
"""猪场生产+财务管理系统"""
from flask import Flask, request, jsonify, send_file, g
import sqlite3, os, json, hashlib, datetime, sys
from functools import wraps
from openpyxl import Workbook
import io

# --- Database adapter: SQLite (local) / PostgreSQL (cloud) ---
DATABASE_URL = os.environ.get('DATABASE_URL')
USE_POSTGRES = bool(DATABASE_URL)

if USE_POSTGRES:
    import psycopg2
    from psycopg2.extras import RealDictCursor
    # Render DATABASE_URL starts with postgres://, need to convert to postgresql://
    if DATABASE_URL.startswith('postgres://'):
        DATABASE_URL = DATABASE_URL.replace('postgres://', 'postgresql://', 1)

def get_db_conn():
    if USE_POSTGRES:
        conn = psycopg2.connect(DATABASE_URL)
        return conn
    else:
        conn = sqlite3.connect(DB_PATH, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        return conn

def db_execute(conn, sql, params=()):
    """Execute SQL with adapter for SQLite/PostgreSQL differences"""
    c = conn.cursor()
    if USE_POSTGRES:
        # Convert ? to %s for PostgreSQL
        sql_pg = sql.replace('?', '%s')
        # Convert datetime('now') to NOW()
        sql_pg = sql_pg.replace('datetime("now")', 'NOW()')
        sql_pg = sql_pg.replace("datetime('now')", 'NOW()')
        c.execute(sql_pg, params)
    else:
        c.execute(sql, params)
    return c

def db_fetchone(cursor):
    """Fetch one row, return dict"""
    row = cursor.fetchone()
    if row is None:
        return None
    if USE_POSTGRES:
        # RealDictCursor returns dict-like
        return dict(row) if hasattr(row, 'keys') else row
    else:
        return dict(row)

def db_fetchall(cursor):
    """Fetch all rows, return list of dicts"""
    rows = cursor.fetchall()
    if USE_POSTGRES:
        return [dict(r) if hasattr(r, 'keys') else r for r in rows]
    else:
        return [dict(r) for r in rows]

def row2dict(row):
    if row is None:
        return None
    if USE_POSTGRES and hasattr(row, 'keys'):
        return dict(row)
    return dict(row) if row else None

# --- PyInstaller frozen mode support ---
if getattr(sys, 'frozen', False):
    import shutil
    BASE_DIR = os.path.dirname(sys.executable)
    FRONTEND_DIR = os.path.join(BASE_DIR, 'frontend')
    MEIPASS = sys._MEIPASS
    # Extract bundled data/ and frontend/ to exe directory on first run
    for _res in ('data', 'frontend'):
        _src = os.path.join(MEIPASS, _res)
        _dst = os.path.join(BASE_DIR, _res)
        if os.path.exists(_src):
            if _res == 'data' and os.path.exists(os.path.join(_dst, 'pig_farm.db')):
                continue  # Don't overwrite existing database
            shutil.copytree(_src, _dst, dirs_exist_ok=True)
else:
    BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    FRONTEND_DIR = os.path.join(BASE_DIR, 'frontend')

DB_PATH = os.path.join(BASE_DIR, 'data', 'pig_farm.db')

app = Flask(__name__, template_folder=FRONTEND_DIR, static_folder=FRONTEND_DIR, static_url_path='/')

# get_db_conn, row2dict moved to top with PostgreSQL support

def login_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token = request.headers.get('Authorization', '').replace('Bearer ', '')
        if not token:
            return jsonify({'code': 401, 'msg': '未登录'}), 401
        conn = get_db_conn()
        c = conn.cursor()
        c.execute('SELECT * FROM users WHERE token=? AND token_exp>datetime("now")', (token,))
        user = c.fetchone()
        if not user:
            return jsonify({'code': 401, 'msg': '登录已过期'}), 401
        g.current_user = row2dict(user)
        return f(*args, **kwargs)
    return decorated

@app.route('/api/login', methods=['POST'])
def login():
    data = request.json or {}
    username = data.get('username', '')
    password = data.get('password', '')
    conn = get_db_conn()
    c = conn.cursor()
    pw_hash = hashlib.md5(password.encode()).hexdigest()
    c.execute('SELECT * FROM users WHERE username=? AND password=?', (username, pw_hash))
    user = c.fetchone()
    if not user:
        return jsonify({'code': 401, 'msg': '用户名或密码错误'})
    token = hashlib.md5((username + datetime.datetime.now().strftime('%Y%m%d%H%M%S')).encode()).hexdigest()
    c.execute("UPDATE users SET token=?, token_exp=datetime('now','+7 days') WHERE id=?", (token, user['id']))
    conn.commit()
    return jsonify({'code': 0, 'data': {'token': token, 'name': user['name'], 'role': user['role'], 'username': user['username']}})

# ============ 个人中心 ============
@app.route('/api/user/profile', methods=['GET'])
@login_required
def get_profile():
    user = g.current_user
    return jsonify({'code': 0, 'data': {
        'id': user['id'],
        'username': user['username'],
        'name': user['name'],
        'role': user['role'],
    }})

@app.route('/api/user/change-password', methods=['POST'])
@login_required
def change_password():
    data = request.json or {}
    old_pwd = data.get('old_password', '')
    new_pwd = data.get('new_password', '')
    confirm_pwd = data.get('confirm_password', '')
    new_username = data.get('username', '').strip()

    if not old_pwd or not new_pwd:
        return jsonify({'code': 400, 'msg': '原密码和新密码不能为空'})
    if len(new_pwd) < 6:
        return jsonify({'code': 400, 'msg': '新密码长度不能少于6位'})
    if new_pwd != confirm_pwd:
        return jsonify({'code': 400, 'msg': '新密码与确认密码不一致'})

    conn = get_db_conn()
    c = conn.cursor()
    user = g.current_user
    old_hash = hashlib.md5(old_pwd.encode()).hexdigest()
    c.execute('SELECT * FROM users WHERE id=? AND password=?', (user['id'], old_hash))
    if not c.fetchone():
        return jsonify({'code': 400, 'msg': '原密码错误'})

    if new_username and new_username != user['username']:
        c.execute('SELECT id FROM users WHERE username=? AND id!=?', (new_username, user['id']))
        if c.fetchone():
            return jsonify({'code': 400, 'msg': '该登录名已被占用'})

    new_hash = hashlib.md5(new_pwd.encode()).hexdigest()
    updates = ['password=?']
    params = [new_hash]
    if new_username and new_username != user['username']:
        updates.append('username=?')
        params.append(new_username)
    params.append(user['id'])
    c.execute('UPDATE users SET ' + ','.join(updates) + ' WHERE id=?', params)
    conn.commit()

    new_token = hashlib.md5(((new_username or user['username']) + datetime.datetime.now().strftime('%Y%m%d%H%M%S')).encode()).hexdigest()
    c.execute("UPDATE users SET token=?, token_exp=datetime('now','+7 days') WHERE id=?", (new_token, user['id']))
    conn.commit()

    return jsonify({'code': 0, 'msg': '修改成功，请使用新账号登录', 'new_token': new_token})


@app.route('/api/dashboard')
@login_required
def get_dashboard():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id', '')
    today = datetime.datetime.now().strftime('%Y-%m-%d')
    month = datetime.datetime.now().strftime('%Y-%m')

    # 1. summary cards
    c.execute('SELECT COUNT(*) as cnt FROM pig_farms')
    farm_count = c.fetchone()['cnt']
    c.execute('SELECT COUNT(*) as cnt FROM barns')
    barn_count = c.fetchone()['cnt']
    c.execute('SELECT COUNT(*) as cnt FROM batches')
    batch_count = c.fetchone()['cnt']

    inv_sql = 'SELECT COALESCE(SUM(quantity),0) as total FROM herds'
    inv_params = []
    if farm_id:
        inv_sql += ' WHERE farm_id=?'
        inv_params.append(farm_id)
    c.execute(inv_sql, inv_params)
    total_inventory = c.fetchone()['total']

    today_sql = 'SELECT COALESCE(SUM(quantity),0) as cnt FROM herds WHERE date(in_date)=?'
    today_params = [today]
    if farm_id:
        today_sql += ' AND farm_id=?'
        today_params.append(farm_id)
    c.execute(today_sql, today_params)
    today_new = c.fetchone()['cnt']

    sales_sql = 'SELECT COALESCE(SUM(quantity),0) as cnt, COALESCE(SUM(total_amount),0) as amt FROM sales_records WHERE sale_date=?'
    sales_params = [today]
    if farm_id:
        sales_sql += ' AND farm_id=?'
        sales_params.append(farm_id)
    c.execute(sales_sql, sales_params)
    sr = c.fetchone()
    today_sales_qty = sr['cnt']
    today_sales_amt = sr['amt']

    death_sql = 'SELECT COALESCE(SUM(quantity),0) as cnt FROM death_records WHERE death_date=?'
    death_params = [today]
    if farm_id:
        death_sql += ' AND farm_id=?'
        death_params.append(farm_id)
    c.execute(death_sql, death_params)
    today_death = c.fetchone()['cnt']

    # 2. inventory by pig_type
    pie_sql = 'SELECT pig_type, SUM(quantity) as total FROM herds'
    pie_params = []
    pie_where = []
    if farm_id:
        pie_where.append('farm_id=?')
        pie_params.append(farm_id)
    if pie_where:
        pie_sql += ' WHERE ' + ' AND '.join(pie_where)
    pie_sql += ' GROUP BY pig_type'
    c.execute(pie_sql, pie_params)
    inventory_by_type = [row2dict(r) for r in c.fetchall()]

    # 3. herd status distribution
    status_sql = 'SELECT status, COUNT(*) as cnt FROM herds'
    status_params = []
    st_where = []
    if farm_id:
        st_where.append('farm_id=?')
        status_params.append(farm_id)
    if st_where:
        status_sql += ' WHERE ' + ' AND '.join(st_where)
    status_sql += ' GROUP BY status'
    c.execute(status_sql, status_params)
    herd_status = [row2dict(r) for r in c.fetchall()]

    # 4. barn inventory
    barn_sql = 'SELECT b.name as barn_name, COALESCE(SUM(h.quantity),0) as total FROM barns b LEFT JOIN herds h ON h.barn_id=b.id'
    barn_params = []
    bw = []
    if farm_id:
        bw.append('b.farm_id=?')
        barn_params.append(farm_id)
    if bw:
        barn_sql += ' WHERE ' + ' AND '.join(bw)
    barn_sql += ' GROUP BY b.id ORDER BY total DESC'
    c.execute(barn_sql, barn_params)
    barn_inventory = [row2dict(r) for r in c.fetchall()]

    # 5. batch summary
    batch_sql = 'SELECT b.batch_code, b.batch_name, b.status, b.quantity, COALESCE(SUM(h.quantity),0) as current_qty FROM batches b LEFT JOIN herds h ON h.batch_id=b.id'
    batch_params = []
    btw = []
    if farm_id:
        btw.append('b.farm_id=?')
        batch_params.append(farm_id)
    if btw:
        batch_sql += ' WHERE ' + ' AND '.join(btw)
    batch_sql += ' GROUP BY b.id ORDER BY b.id DESC'
    c.execute(batch_sql, batch_params)
    batch_summary = [row2dict(r) for r in c.fetchall()]

    # 6. immune reminders
    immune_sql = "SELECT ir.id, ir.herd_id, ir.vaccine_name, ir.immune_type, ir.reminder_date, ir.status, ir.dosage, ir.immune_method, h.herd_code, h.herd_name, b.batch_code FROM immune_reminders ir LEFT JOIN herds h ON h.id=ir.herd_id LEFT JOIN batches b ON b.id=h.batch_id WHERE ir.reminder_date <= date('now', '+7 days') AND (ir.status IS NULL OR ir.status != 'done')"
    immune_params = []
    if farm_id:
        immune_sql += ' AND ir.farm_id=?'
        immune_params.append(farm_id)
    immune_sql += ' ORDER BY ir.reminder_date LIMIT 20'
    try:
        c.execute(immune_sql, immune_params)
        immune_reminders = [row2dict(r) for r in c.fetchall()]
    except Exception:
        immune_reminders = []

    # 7. monthly cost breakdown
    cost_sql = 'SELECT cost_category, COALESCE(SUM(amount),0) as amount FROM cost_records WHERE month=?'
    cost_params = [month]
    if farm_id:
        cost_sql += ' AND farm_id=?'
        cost_params.append(farm_id)
    cost_sql += ' GROUP BY cost_category'
    c.execute(cost_sql, cost_params)
    monthly_cost = [row2dict(r) for r in c.fetchall()]

    # 8. monthly income & cost total
    inc_sql = 'SELECT COALESCE(SUM(amount),0) as total FROM income_records WHERE month=?'
    inc_params = [month]
    if farm_id:
        inc_sql += ' AND farm_id=?'
        inc_params.append(farm_id)
    c.execute(inc_sql, inc_params)
    monthly_income = c.fetchone()['total']

    cost_total_sql = 'SELECT COALESCE(SUM(amount),0) as total FROM cost_records WHERE month=?'
    cost_total_params = [month]
    if farm_id:
        cost_total_sql += ' AND farm_id=?'
        cost_total_params.append(farm_id)
    c.execute(cost_total_sql, cost_total_params)
    monthly_cost_total = c.fetchone()['total']

    # 9. recent production records
    recent_records = []
    rs_sql = "SELECT sale_date as record_date, pig_type, quantity, total_amount as extra FROM sales_records"
    rs_p = []
    rs_w = []
    if farm_id:
        rs_w.append('farm_id=?')
        rs_p.append(farm_id)
    if rs_w:
        rs_sql += ' WHERE ' + ' AND '.join(rs_w)
    rs_sql += ' ORDER BY id DESC LIMIT 5'
    c.execute(rs_sql, rs_p)
    for r in c.fetchall():
        d = row2dict(r)
        d['type'] = 'sale'
        recent_records.append(d)

    rd_sql = "SELECT death_date as record_date, pig_type, quantity, reason as extra FROM death_records"
    rd_p = []
    rd_w = []
    if farm_id:
        rd_w.append('farm_id=?')
        rd_p.append(farm_id)
    if rd_w:
        rd_sql += ' WHERE ' + ' AND '.join(rd_w)
    rd_sql += ' ORDER BY id DESC LIMIT 5'
    c.execute(rd_sql, rd_p)
    for r in c.fetchall():
        d = row2dict(r)
        d['type'] = 'death'
        recent_records.append(d)

    recent_records.sort(key=lambda x: x.get('record_date') or '', reverse=True)
    recent_records = recent_records[:10]

    conn.close()

    return jsonify({'code': 0, 'data': {
        'summary': {
            'farm_count': farm_count, 'barn_count': barn_count, 'batch_count': batch_count,
            'total_inventory': total_inventory, 'today_new': today_new,
            'today_sales_qty': today_sales_qty, 'today_sales_amt': today_sales_amt,
            'today_death': today_death,
        },
        'inventory_by_type': inventory_by_type,
        'herd_status': herd_status,
        'barn_inventory': barn_inventory,
        'batch_summary': batch_summary,
        'immune_reminders': immune_reminders,
        'monthly_cost': monthly_cost,
        'monthly_income': monthly_income,
        'monthly_cost_total': monthly_cost_total,
        'recent_records': recent_records,
    }})


def crud_list(table, extra_cols=None):
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id')
    keyword = request.args.get('keyword', '')
    page = int(request.args.get('page', 1))
    page_size = int(request.args.get('page_size', 50))
    offset = (page - 1) * page_size
    cols = extra_cols or ['*']
    sql = f'SELECT {",".join(cols)} FROM {table}'
    params = []
    conditions = []
    if farm_id:
        conditions.append(f'{table}.farm_id=?')
        params.append(farm_id)
    if keyword and 'name' in str(extra_cols or ['*']):
        conditions.append(f'{table}.name LIKE ?')
        params.append(f'%{keyword}%')
    if conditions:
        sql += ' WHERE ' + ' AND '.join(conditions)
    sql += f' ORDER BY {table}.id DESC LIMIT {page_size} OFFSET {offset}'
    c.execute(sql, params)
    rows = [row2dict(r) for r in c.fetchall()]
    return jsonify({'code': 0, 'data': rows, 'total': len(rows)})

def crud_create(table, fields):
    data = request.json or {}
    cols = [f for f in fields if f in data]
    vals = [data.get(f) for f in cols]
    conn = get_db_conn()
    c = conn.cursor()
    c.execute(f"INSERT INTO {table} ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '创建成功', 'id': c.lastrowid})

def crud_update(table, fields, id):
    data = request.json or {}
    sets = [f'{f}=?' for f in fields if f in data]
    vals = [data.get(f) for f in fields if f in data] + [id]
    conn = get_db_conn()
    c = conn.cursor()
    c.execute(f"UPDATE {table} SET {','.join(sets)} WHERE id=?", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '更新成功'})

def crud_delete(table, id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute(f'DELETE FROM {table} WHERE id=?', (id,))
    conn.commit()
    return jsonify({'code': 0, 'msg': '删除成功'})

def crud_get(table, id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute(f'SELECT * FROM {table} WHERE id=?', (id,))
    row = c.fetchone()
    if not row:
        return jsonify({'code': 404, 'msg': '记录不存在'})
    return jsonify({'code': 0, 'data': row2dict(row)})

