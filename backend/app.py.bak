@app.route('/api/batches', methods=['POST'])
@login_required
def create_batch():
    data = request.json or {}
    farm_id = data.get('farm_id', 1)
    today = datetime.datetime.now().strftime('%Y%m%d')
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT COUNT(*) FROM batches WHERE batch_code LIKE ?', (f'PC{today}%',))
    cnt = c.fetchone()[0] or 0
    batch_code = f'PC{today}{str(cnt+1).zfill(3)}'
    data['batch_code'] = batch_code
    if not data.get('status'):
        data['status'] = '进行中'
    cols = ['batch_code', 'batch_name', 'farm_id', 'batch_type', 'start_date', 'expected_end_date', 'quantity', 'status', 'manager', 'notes']
    vals = [data.get(f) for f in cols]
    c.execute(f"INSERT INTO batches ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '创建成功', 'id': c.lastrowid, 'batch_code': batch_code})

@app.route('/api/batches/<int:id>', methods=['GET'])
@login_required
def get_batch(id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT b.*, f.name as farm_name FROM batches b LEFT JOIN pig_farms f ON b.farm_id=f.id WHERE b.id=?', (id,))
    row = c.fetchone()
    if not row:
        return jsonify({'code': 404, 'msg': '批次不存在'})
    return jsonify({'code': 0, 'data': row2dict(row)})

@app.route('/api/batches/<int:id>', methods=['PUT'])
@login_required
def update_batch(id):
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT status FROM batches WHERE id=?', (id,))
    row = c.fetchone()
    if row and row['status'] == '已完成' and data.get('status') != '已完成':
        return jsonify({'code': 400, 'msg': '已完成的批次只能修改状态'})
    cols = ['batch_name', 'batch_type', 'start_date', 'expected_end_date', 'quantity', 'status', 'manager', 'notes']
    vals = [data.get(f) for f in cols] + [id]
    c.execute(f"UPDATE batches SET {','.join([f'{f}=?' for f in cols])} WHERE id=?", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '更新成功'})

@app.route('/api/batches/<int:id>', methods=['DELETE'])
@login_required
def delete_batch(id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT COUNT(*) FROM herds WHERE batch_id=?', (id,))
    cnt = c.fetchone()[0] or 0
    if cnt > 0:
        return jsonify({'code': 400, 'msg': f'该批次有{cnt}个猪群关联，不允许删除'})
    c.execute('DELETE FROM batches WHERE id=?', (id,))
    conn.commit()
    return jsonify({'code': 0, 'msg': '删除成功'})

# ============ 猪群 ============
@app.route('/api/herds', methods=['GET'])
@login_required
def list_herds():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id')
    batch_id = request.args.get('batch_id')
    status = request.args.get('status')
    keyword = request.args.get('keyword', '')
    sql = 'SELECT h.*, bt.batch_code, bt.batch_name, f.name as farm_name, b.name as barn_name FROM herds h LEFT JOIN batches bt ON h.batch_id=bt.id LEFT JOIN pig_farms f ON h.farm_id=f.id LEFT JOIN barns b ON h.barn_id=b.id WHERE 1=1'
    params = []
    if farm_id: sql += ' AND h.farm_id=?'; params.append(farm_id)
    if batch_id: sql += ' AND h.batch_id=?'; params.append(batch_id)
    if status: sql += ' AND h.status=?'; params.append(status)
    if keyword: sql += ' AND (h.herd_code LIKE ? OR h.herd_name LIKE ?)'; params.extend([f'%{keyword}%', f'%{keyword}%'])
    sql += ' ORDER BY h.id DESC'
    c.execute(sql, params)
    return jsonify({'code': 0, 'data': [row2dict(r) for r in c.fetchall()]})

@app.route('/api/herds', methods=['POST'])
@login_required
def create_herd():
    data = request.json or {}
    if not data.get('batch_id'):
        return jsonify({'code': 400, 'msg': '猪群必须选择批次'})
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT farm_id, batch_type FROM batches WHERE id=?', (data['batch_id'],))
    batch = c.fetchone()
    if batch:
        if not data.get('farm_id'): data['farm_id'] = batch['farm_id']
        if not data.get('pig_type'): data['pig_type'] = batch['batch_type'] or '育肥猪'
    if not data.get('herd_code'):
        today = datetime.datetime.now().strftime('%Y%m%d')
        c.execute('SELECT COUNT(*) FROM herds WHERE herd_code LIKE ?', (f'H{today}%',))
        cnt = c.fetchone()[0] or 0
        data['herd_code'] = f'H{today}{str(cnt+1).zfill(3)}'
    if not data.get('status'): data['status'] = '存栏'
    cols = ['farm_id', 'barn_id', 'batch_id', 'herd_code', 'herd_name', 'pig_type', 'quantity', 'weight', 'age_days', 'in_date', 'transfer_date', 'status', 'notes']
    vals = [data.get(f) for f in cols]
    c.execute(f"INSERT INTO herds ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '创建成功', 'id': c.lastrowid, 'herd_code': data.get('herd_code')})

@app.route('/api/herds/<int:id>', methods=['PUT'])
@login_required
def update_herd(id):
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    if not data.get('batch_id'):
        return jsonify({'code': 400, 'msg': '猪群必须选择批次'})
    cols = ['farm_id', 'barn_id', 'batch_id', 'herd_code', 'herd_name', 'pig_type', 'quantity', 'weight', 'age_days', 'in_date', 'transfer_date', 'status', 'notes']
    vals = [data.get(f) for f in cols] + [id]
    c.execute(f"UPDATE herds SET {','.join([f'{f}=?' for f in cols])} WHERE id=?", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '更新成功'})

