@app.route('/api/death_records', methods=['GET'])
@login_required
def list_death():
    conn = get_db_conn()
    c = conn.cursor()
    farm_id = request.args.get('farm_id')
    batch_id = request.args.get('batch_id')
    sql = 'SELECT dr.*, bt.batch_code, bt.batch_name, h.herd_code, h.herd_name, h.pig_type FROM death_records dr LEFT JOIN batches bt ON dr.batch_id=bt.id LEFT JOIN herds h ON dr.herd_id=h.id WHERE 1=1'
    params = []
    if farm_id: sql += ' AND dr.farm_id=?'; params.append(farm_id)
    if batch_id: sql += ' AND dr.batch_id=?'; params.append(batch_id)
    sql += ' ORDER BY dr.id DESC'
    c.execute(sql, params)
    return jsonify({'code': 0, 'data': [row2dict(r) for r in c.fetchall()]})

@app.route('/api/death_records', methods=['POST'])
@login_required
def create_death():
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    if not data.get('farm_id'):
        if data.get('batch_id'):
            c.execute('SELECT farm_id FROM batches WHERE id=?', (data['batch_id'],))
            b = c.fetchone()
            if b: data['farm_id'] = b['farm_id']
        elif data.get('herd_id'):
            c.execute('SELECT farm_id, pig_type FROM herds WHERE id=?', (data['herd_id'],))
            h = c.fetchone()
            if h:
                data['farm_id'] = h['farm_id']
                if not data.get('pig_type'): data['pig_type'] = h['pig_type']
        if not data.get('farm_id'):
            data['farm_id'] = 1  # fallback to first farm
    qty = int(data.get('quantity', 0) or 0)
    herd_id = data.get('herd_id')
    cols = ['farm_id', 'batch_id', 'herd_id', 'pig_type', 'barn_name', 'quantity', 'death_type', 'reason', 'death_date', 'operator', 'notes']
    vals = [data.get(f) for f in cols]
    c.execute(f"INSERT INTO death_records ({','.join(cols)}) VALUES ({','.join(['?']*len(cols))})", vals)
    conn.commit()
    # Decrement batch/herd inventory on death (only when herd was linked)
    batch_id = data.get('batch_id')
    if batch_id and herd_id and qty > 0:
        c.execute('UPDATE batches SET current_quantity=COALESCE(current_quantity,0)-? WHERE id=?', (qty, batch_id))
        conn.commit()
    return jsonify({'code': 0, 'msg': '添加成功'})
@app.route('/api/death_records/<int:id>', methods=['PUT'])
@login_required
def update_death(id):
    data = request.json or {}
    conn = get_db_conn()
    c = conn.cursor()
    cols = ['farm_id', 'batch_id', 'herd_id', 'pig_type', 'barn_name', 'quantity', 'death_type', 'reason', 'death_date', 'operator', 'notes']
    vals = [data.get(f) for f in cols] + [id]
    c.execute(f"UPDATE death_records SET {','.join([f'{f}=?' for f in cols])} WHERE id=?", vals)
    conn.commit()
    return jsonify({'code': 0, 'msg': '更新成功'})

@app.route('/api/death_records/<int:id>', methods=['DELETE'])
@login_required
def delete_death(id):
    conn = get_db_conn()
    c = conn.cursor()
    c.execute('SELECT herd_id, batch_id, quantity FROM death_records WHERE id=?', (id,))
    row = c.fetchone()
    qty = int(row['quantity'] or 0) if row else 0
    c.execute('DELETE FROM death_records WHERE id=?', (id,))
    conn.commit()
    # Only restore inventory when herd was linked (symmetric with create_death)
    if row and row['herd_id'] and qty > 0:
        c.execute('UPDATE herds SET quantity=COALESCE(quantity,0)+?, status=? WHERE id=?', (qty, '存栏', row['herd_id']))
        conn.commit()
        if row['batch_id']:
            c.execute('UPDATE batches SET current_quantity=COALESCE(current_quantity,0)+? WHERE id=?', (qty, row['batch_id']))
            conn.commit()
    return jsonify({'code': 0, 'msg': '删除成功'})

